# ── JanSetu Backend Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in real values before running.

# Server
PORT=8000
FRONTEND_URL=http://localhost:5173

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here

# Google Cloud (Vertex AI, BigQuery, Storage, Speech, Translate)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
VERTEX_AI_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# BigQuery
BIGQUERY_DATASET=jansetu_mvp

# Firebase / Firestore
FIREBASE_SERVICE_ACCOUNT=path/to/firebase-service-account.json

# Google Maps
GOOGLE_MAPS_API_KEY=your-maps-api-key-here

# WhatsApp Business API (optional)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# Twilio SMS (optional fallback)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
