# =============================================================
# JanSetu — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================

# ── GCP / Vertex AI ──────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-new-project-id
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
VERTEX_AI_LOCATION=us-central1

# ── Gemini API (AI Studio key — used by frontend + backend) ──
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google Maps ───────────────────────────────────────────────
# Enable: Maps JavaScript API + Distance Matrix API in GCP Console
GOOGLE_MAPS_API_KEY=your_maps_api_key_here

# ── Firebase (link your GCP project to Firebase Console) ──────
# Get all 6 from: Firebase Console → Project Settings → Web App → SDK config
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── BigQuery ──────────────────────────────────────────────────
BIGQUERY_DATASET=jansetu_mvp

# ── Backend Server ────────────────────────────────────────────
PORT=8000
FRONTEND_URL=http://localhost:5173

# ── WhatsApp Business API (OPTIONAL — stub used if blank) ─────
# Get from: Meta for Developers → WhatsApp → sandbox
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ── SMS via Twilio (OPTIONAL — stub used if blank) ────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
